DB_HOST=localhost
DB_PORT=5432
DB_NAME=rdc_news
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rdc_news
DISABLE_DATASET_AUTOLOAD=true
CRAWLER_BACKEND_ENDPOINT=http://127.0.0.1:8000
BACKEND_ENDPOINT=http://127.0.0.1:8000
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=mistral:7b-instruct-v0.3-q4_K_M
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_BATCH=128
# Messagerie : éviter la coupure au milieu de l’explication (ancien 120 tokens ≈ 2–3 phrases).
OLLAMA_NUM_PREDICT_MSG=256
OLLAMA_NUM_PREDICT_WEB=300
OLLAMA_FALLBACK_MODELS=mistral:latest,mistral
USE_LLM_RAG=true
TELEGRAM_BOT_TOKEN=8574084394:AAFssm4-IOiXVF4b0aQXwztUNrwsDKGW4JM
TELEGRAM_BACKEND_ENDPOINT=http://127.0.0.1:8000
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_TOP_K=2
TELEGRAM_USE_RAG=true
TELEGRAM_POLLING=true
WHATSAPP_TOKEN=EAAcZBMWRH4G4BRVg1FZCDitt7WFQC8ZAIaeeb3JLF2dUQyl5r2QLlZAoJYE9NYEtvuZBUKGZAoc78yKe7nJFZAjjoYzZA42SfqAAmQWGWztZC29WeZC6c646RPElxmc4P2YLvp6yC59XdQM322TdtY23u4SmkaSJaI0CstJwQDjjsnxTsOu2Epo21oBZCp7OT26VgZDZD
WHATSAPP_PHONE_ID=1035833856284644
ENABLE_WHATSAPP_QUEUE_POLLING=false
WHATSAPP_QUEUE_POP_URL=https://rooney-rdc.rooneykalumba.tech/webhooks/whatsapp/queue/pop
WHATSAPP_QUEUE_TOKEN=secret-queue
WHATSAPP_QUEUE_POLL_INTERVAL=2
WHATSAPP_QUEUE_TIMEOUT=15

WHATSAPP_REPLY_RELAY_URL=https://rooney-rdc.rooneykalumba.tech/webhooks/whatsapp/reply-relay
WHATSAPP_REPLY_RELAY_TIMEOUT=15
RAG_MIN_SIMILARITY=0.36
RAG_MIN_SIMILARITY_MSG=0.40
WHATSAPP_VERIFY_TOKEN=rdc_news_token
WHATSAPP_REPLY_RELAY_TOKEN=secret-relay
WHATSAPP_ACK_IF_NO_TYPING=false 
WHATSAPP_CHUNK_MIN_CHARS=220    
WHATSAPP_WEBHOOK_PROXY_ONLY=false
# Ne charge que .env_file si exporté AVANT pm2 (sinon .env sur le VPS peut écraser) :
# export RDC_ENV_FILE_ONLY=1
RDC_LOG_FILE=.logs/fastapi.log

# --- Optimisations RAG ---
RAG_ENABLE_RERANK=false
RAG_WEB_TOP_K=2
WHATSAPP_TOP_K=2
TOPIC_GATE_KEYWORD_MODE=keywords-first
TOPIC_GATE_TIMEOUT=15

# --- Whapi.Cloud : `POST /webhooks/whapi` — même RAG + topic gate en groupe (`chat_id` se terminant par @g.us).
# Enregistrer le webhook permanent (pas seulement webhook_test) : PATCH https://gate.whapi.cloud/settings
# Doc : https://support.whapi.cloud/help-desk/receiving/webhooks/set-the-webhook-link-to-the-channel
WHAPI_TOKEN=NF7WI9enkxstmWF8wVtF9BaQfWUGTRip
WHAPI_API_BASE=https://gate.whapi.cloud
WHAPI_HTTP_TIMEOUT=60
# Si défini, le webhook doit envoyer le header `X-RDC-Whapi-Secret` avec la même valeur :
# WHAPI_WEBHOOK_SECRET=
#
# Topologie VPS tout-en-un : file + polling + relay en local (127.0.0.1).
# Le domaine public sert uniquement au webhook entrant Whapi → Nginx → :8000
WHAPI_WEBHOOK_PROXY_ONLY=true
ENABLE_WHAPI_QUEUE_POLLING=true
# WHAPI_QUEUE_TOKEN / WHAPI_REPLY_RELAY_TOKEN : voir WHATSAPP_QUEUE_TOKEN et WHATSAPP_REPLY_RELAY_TOKEN ci-dessus
WHAPI_QUEUE_POP_URL=http://127.0.0.1:8000/webhooks/whapi/queue/pop
WHAPI_REPLY_RELAY_URL=http://127.0.0.1:8000/webhooks/whapi/reply-relay

REDIS_URL=redis://127.0.0.1:6379/0
