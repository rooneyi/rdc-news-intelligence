# =============================================================================
# RDC News Intelligence — variables PRODUCTION (VPS tout-en-un)
# =============================================================================
# Copier sur le VPS :
#   cp .env.production.example .env
#   nano .env   # remplir les secrets (WHAPI_TOKEN, mots de passe DB, etc.)
#
# Le service PM2 charge automatiquement ce fichier au démarrage Python
# (voir app/core/config.py). Pas besoin de « export » dans le shell pour PM2.
#
# Pour le crawler en ligne de commande, soit les variables sont dans .env,
# soit : export $(grep -v '^#' .env | xargs)  avant la commande sync.
# =============================================================================

APP_PORT=8000
LOG_LEVEL=INFO

# --- Base de données (préférer DB_* ; évite DATABASE_URL obsolète) ---
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=rdc_news
DB_USER=rdc_user
DB_PASSWORD=CHANGER_MOT_DE_PASSE
# DATABASE_FROM_URL_ONLY=1
# DATABASE_URL=postgresql://rdc_user:...@127.0.0.1:5432/rdc_news

REDIS_URL=redis://127.0.0.1:6379/0

# --- Ollama (même VPS) ---
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=mistral:7b-instruct-v0.3-q4_K_M
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_PREDICT_MSG=512
RAG_ENABLE_RERANK=false
RAG_MIN_SIMILARITY=0.36
RAG_MIN_SIMILARITY_MSG=0.40

# --- Crawler → API locale (obligatoire pour sync vers PostgreSQL/Chroma) ---
CRAWLER_BACKEND_ENDPOINT=http://127.0.0.1:8000
# BACKEND_ENDPOINT=http://127.0.0.1:8000

# --- Whapi / WhatsApp (profil qui fonctionnait avant expiration VPS) ---
WHAPI_TOKEN=NF7WI9enkxstmWF8wVtF9BaQfWUGTRip
WHAPI_WEBHOOK_PROXY_ONLY=true
ENABLE_WHAPI_QUEUE_POLLING=true
WHAPI_QUEUE_TOKEN=secret_queue_long_et_aleatoire
WHAPI_REPLY_RELAY_TOKEN=secret_relay_long_et_aleatoire
WHAPI_QUEUE_POP_URL=http://127.0.0.1:8000/webhooks/whapi/queue/pop
WHAPI_REPLY_RELAY_URL=http://127.0.0.1:8000/webhooks/whapi/reply-relay
WHAPI_QUEUE_POLL_INTERVAL=2
# WHAPI_WEBHOOK_SECRET=optionnel_si_configure_chez_whapi

# --- Telegram (optionnel) ---
TELEGRAM_BOT_TOKEN=8574084394:AAFssm4-IOiXVF4b0aQXwztUNrwsDKGW4JM
ENABLE_TELEGRAM_POLLING=false

# --- Topic gate (groupes WhatsApp) ---
TOPIC_GATE_KEYWORD_MODE=hybrid
TOPIC_GATE_MIN_CONFIDENCE=0.6
# TOPIC_GATE_REPLY_WHEN_IGNORED=true

# --- Mémoire conversationnelle (désactivée = comportement d’origine, 1 RAG par message) ---
CONVERSATIONAL_MEMORY_ENABLED=false
MEMORY_TTL_SECONDS=3600
# Seuil élevé : évite « constitution » ≈ « révolte constitution » (0.85 était trop bas)
MEMORY_SIMILARITY_THRESHOLD=0.94
# Mode raffiné seulement à partir de la N-ième question très proche dans le même chat
MEMORY_REFINE_MIN_OCCURRENCE=2
# Alerte viralité seulement si le sujet a circulé dans au moins N chats
MEMORY_VIRAL_MIN_GROUPS=3
# Préfixe « Sujet déjà abordé » (laisser false en prod)
MEMORY_SHOW_REPEAT_NOTE=false
# Anti-doublon webhook / file Whapi (recommandé)
WHATSAPP_DEDUP_INBOUND=true
WHATSAPP_INBOUND_DEDUP_TTL_SECONDS=86400
# Si comportement bizarre : redis-cli DEL global_topics_index ; redis-cli --scan --pattern 'chat_history:*' | xargs redis-cli DEL

# --- Cron crawler (désactiver pendant tests WhatsApp si RAM juste) ---
ENABLE_CRON_JOBS=true

# --- OCR images WhatsApp ---
OCR_LANG=fra+eng
# OCR_MIN_SIDE_PX=900
# TESSERACT_CMD=/usr/bin/tesseract
WHAPI_MEDIA_USE_AUTH=true
WHATSAPP_MEDIA_TIMEOUT=120

# --- Désactiver autoload dataset HuggingFace au boot si corpus déjà en DB ---
DISABLE_DATASET_AUTOLOAD=true
