```mermaid
graph TD
    %% Clients
    U[Utilisateur / Journaliste]

    subgraph Channels[Canaux de conversation]
        W[Frontend Web (Next.js)]
        T[Telegram Bot]
        WA[WhatsApp Cloud API]
    end

    U --> W
    U --> T
    U --> WA

    %% FastAPI Service
    subgraph AI[AI-Service (FastAPI app.main)]
        subgraph API[Routes FastAPI]
            A1[/POST /rag\nPOST /rag/stream\nPOST /rag/image/]
            A2[/Routes articles & crawler/]
            WH[/Webhooks Telegram & WhatsApp/]
        end

        subgraph Services[Services internes]
            RAG[RAGService]
            EMB[EmbeddingService]
            RET[RetrievalService]
            LLM[LLMService (Ollama/Mistral)]
            OCR[OCRService (pytesseract)]
            LOAD[Dataset Loader / Crawler Jobs]
        end
    end

    %% External deps
    subgraph DB[PostgreSQL + pgvector]
        ART[(Table articles\n+ embeddings)]
    end

    subgraph Ollama[Ollama]
        M[Mistral LLM]
    end

    subgraph OCRDeps[OCR système]
        TES[Tesseract binaire]
    end

    subgraph MessagingAPIs[APIs externes]
        TGAPI[Telegram Bot API]
        WAAPI[WhatsApp Cloud API]
    end

    %% Flots clients → API
    W -->|HTTP JSON| A1
    T -->|Messages utilisateur| TGAPI --> WH
    WA -->|Webhook HTTP| WAAPI --> WH

    %% Webhooks & RAG
    WH -->|Texte ou image (après téléchargement)| OCR
    A1 -->|Texte direct ou OCR| OCR

    OCR -->|Texte extrait| RAG

    RAG --> EMB
    EMB --> RET
    RET --> ART
    RAG --> LLM
    LLM --> M

    %% Réponses
    RAG -->|Réponse + sources| A1
    RAG -->|Texte à renvoyer| WH

    %% Stockage & jobs
    LOAD --> ART

    %% Dépendances bas niveau
    OCR --> TES
```